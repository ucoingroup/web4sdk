{
  "name": "@eaco/web4sdk",
  "version": "1.0.0",
  "description": "EACO Web4 SDK — 连接虚拟宇宙与去中心化金融的开发者工具包",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm test"
  },
  "author": "EACO Group",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ucoingroup/web4sdk.git"
  },
  "bugs": {
    "url": "https://github.com/ucoingroup/web4sdk/issues"
  },
  "homepage": "https://github.com/ucoingroup/web4sdk#readme",
  "sideEffects": false,
  "keywords": [
    "eaco",
    "web4",
    "sdk",
    "solana",
    "defi",
    "blockchain",
    "agent-world",
    "virtual-universe"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@solana/web3.js": "^1.87.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
