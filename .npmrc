# NPM Configuration for Web4SDK
# See https://docs.npmjs.com/cli/v10/configuring-npm/npmrc

# Use default NPM registry
registry=https://registry.npmjs.org/

# Always require package-lock.json (reproducible builds)
package-lock=true

# Automatically save installed packages to dependencies
save=true

# Use strict semver for peer dependencies
legacy-peer-deps=false

# Enable stricter checksum validation
install-strategy=nested

# Log level
loglevel=notice

# Prevent NPM from automatically creating package-lock.json for global installs
package-lock-only=false

# Timeout for network requests (ms)
fetch-timeout=60000

# Number of retries for network requests
fetch-retries=3

# Enable strict SSL certificate validation
strict-ssl=true
